# Hidden directories and OS files
.*/
.DS_Store
Thumbs.db

# Python cache
__pycache__/
*.py[cod]
*$py.class
*.so
.Python

# Virtual environments
venv/
env/
ENV/

# IDE
.vscode/
.idea/
*.swp
*.swo
*~

# Environment variables (NEVER commit credentials!)
.env
.env.local
.env.*.local
.env.development.local
.env.production.local
.env.test.local

# EXCEPTION: These should be committed (not in gitignore):
# .env.template        - Template with documentation
# .env.development     - Frontend development config (no secrets)
# .env.production      - Frontend production config (no secrets)

# DuckDB workspace files
*.duckdb
*.duckdb.wal
lineage_workspace.*

# Parquet snapshots (may contain sensitive data)
parquet_snapshots/
parquet_snapshots/*.parquet

# Metadata cache (contains database object names)
metadata_cache.json

# Temp folder (uploaded parquet files and development artifacts)
temp/

# Lineage output (generated files should not be tracked - MAY CONTAIN SENSITIVE DATA)
lineage_output/*.json
api/lineage_output/
engine/lineage_output/
lineage.json
lineage_summary.json
frontend_lineage.json
latest_frontend_lineage.json

# Testing results (query log validation)
testing/query_log_validation/results/*.json
testing/query_log_validation/results/*.md
# API persistent data
api/data/
data/

# Log files (should never be committed)
*.log

# Database files
*.db
*.sqlite

# Build artifacts
dist/
build/
*.egg-info/

# Azure deployment package (generated file)
lineage-visualizer-azure.zip
package_temp/
*.log

# Azure log downloads (temporary debugging files)
azure-logs.zip
azure-logs/

# Temporary scripts and testing (keep root clean)
temp/
